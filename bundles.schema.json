{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "profile-router bundles.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["profiles"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/definitions/profile" }
    },
    "default": {
      "$ref": "#/definitions/partialProfile"
    }
  },
  "definitions": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "keywords"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "verbs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Weak/rhetorical action words; weight 1 (e.g. 'explain', 'find')."
        },
        "scopes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Code-element or breadth nouns; weight 2 (e.g. 'function', 'repository')."
        },
        "excludeKeywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Any hit disqualifies this profile (score = -Infinity)."
        },
        "minScore": {
          "type": "number",
          "description": "Qualifying score threshold for this profile; default 1 (preserves legacy score>0 routing)."
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": { "type": "boolean" },
            "write": { "type": "boolean" },
            "execute": { "type": "boolean" }
          },
          "description": "Declarative capability flags; write:false profiles get the read-only escape-hatch rule convention."
        },
        "suppresses": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Rule tags this profile removes from the merged rule set (union across all matched profiles; destructive, order-independent)."
        },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/definitions/ruleEntry" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disabledAgents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "model": {
          "type": "array",
          "items": { "type": "string" }
        },
        "thinkingLevel": {
          "type": "string",
          "enum": ["off", "low", "medium", "high"]
        }
      }
    },
    "ruleEntry": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag", "text"],
          "properties": {
            "tag": { "type": "string", "minLength": 1 },
            "text": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "partialProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/definitions/ruleEntry" }
        },
        "commonRules": {
          "type": "array",
          "items": { "$ref": "#/definitions/ruleEntry" },
          "description": "Rules shared by every profile (e.g. the truncation-handling rule); merged as default -> commonRules -> profile.rules, deduped by text."
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disabledAgents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "model": {
          "type": "array",
          "items": { "type": "string" }
        },
        "thinkingLevel": {
          "type": "string",
          "enum": ["off", "low", "medium", "high"]
        }
      }
    }
  }
}
