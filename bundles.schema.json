{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "profile-router bundles.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["profiles"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/definitions/profile" }
    },
    "default": {
      "$ref": "#/definitions/partialProfile"
    }
  },
  "definitions": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "keywords"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disabledAgents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "model": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "thinkingLevel": {
          "type": "string",
          "enum": ["off", "low", "medium", "high"]
        }
      }
    },
    "partialProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disabledAgents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "model": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "thinkingLevel": {
          "type": "string",
          "enum": ["off", "low", "medium", "high"]
        }
      }
    }
  }
}
